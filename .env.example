# API key to protect the relay (optional, open if not set)
RELAY_API_KEY=your-secret-key-here

# Add extra targets at runtime without redeploying (optional)
# Format: JSON object mapping alias → base URL
# RELAY_EXTRA_TARGETS={"custom-api":"https://api.example.com","another":"https://another.service.io"}

# Optional Phase 10 truth sidecar target
SHADOW_SIDECAR_URL=https://your-sidecar.example.com
SHADOW_SIDECAR_TOKEN=your-sidecar-bearer-token
